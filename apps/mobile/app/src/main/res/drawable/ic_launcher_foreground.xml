<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- NotiFlow launcher icon: rounded bell + flow curves + notification badge -->
    <!-- Safe zone: 54±36 = 18..90 (72dp center area) -->

    <group
        android:translateX="54"
        android:translateY="50">

        <!-- Bell body: smooth rounded bell curve -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="
                M0,-28
                C-3,-28 -5,-26 -5,-23
                L-5,-18
                C-5,-12 -8,-6 -13,-2
                C-15,0 -16,2 -16,5
                L16,5
                C16,2 15,0 13,-2
                C8,-6 5,-12 5,-18
                L5,-23
                C5,-26 3,-28 0,-28
                Z"/>

        <!-- Bell rim: rounded rectangle at bottom -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="
                M-19,5
                L19,5
                A3,3 0,0 1,19 11
                L-19,11
                A3,3 0,0 1,-19 5
                Z"/>

        <!-- Bell clapper: small rounded shape at bottom -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="
                M-5,12
                C-5,17 -3,20 0,20
                C3,20 5,17 5,12
                Z"/>

        <!-- Bell handle: small arch at top -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="
                M-4,-28
                C-4,-33 4,-33 4,-28"
            android:strokeWidth="3"
            android:strokeColor="#FFFFFF"
            android:strokeLineCap="round"/>

        <!-- Notification badge: filled circle top-right with inner dot -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M14,-22 m-7,0 a7,7 0,1 1,14 0 a7,7 0,1 1,-14 0"/>
        <!-- Badge inner highlight -->
        <path
            android:fillColor="#E8729D"
            android:pathData="M14,-22 m-3.5,0 a3.5,3.5 0,1 1,7 0 a3.5,3.5 0,1 1,-7 0"/>

        <!-- Flow wave 1: primary S-curve -->
        <path
            android:fillColor="#00000000"
            android:strokeWidth="3"
            android:strokeColor="#FFFFFF"
            android:strokeAlpha="0.85"
            android:strokeLineCap="round"
            android:pathData="M-22,28 Q-11,22 0,28 Q11,34 22,28"/>

        <!-- Flow wave 2: secondary wave (thinner, more transparent) -->
        <path
            android:fillColor="#00000000"
            android:strokeWidth="2"
            android:strokeColor="#FFFFFF"
            android:strokeAlpha="0.45"
            android:strokeLineCap="round"
            android:pathData="M-18,34 Q-9,29 0,34 Q9,39 18,34"/>

    </group>
</vector>
