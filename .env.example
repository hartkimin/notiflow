# ===========================================
# NotiFlow Monorepo - Environment Variables
# ===========================================

# --- apps/web (.env.local) ---
# Used by Next.js dashboard (set in Vercel Dashboard for production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- packages/supabase (Edge Functions Secrets) ---
# Set via: supabase secrets set KEY=value
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key
FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# --- packages/supabase (DB Webhook Config) ---
# Set via SQL after deployment:
#   ALTER DATABASE postgres SET app.settings.supabase_url = 'https://your-project.supabase.co';
#   ALTER DATABASE postgres SET app.settings.service_role_key = 'your-service-role-key';
