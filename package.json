{
  "name": "notiflow",
  "version": "1.0.0",
  "private": true,
  "description": "NotiFlow - Medical supply order notification system",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "lint:web": "npm run lint --workspace=apps/web",
    "supabase:start": "npx supabase start -w packages/supabase",
    "supabase:stop": "npx supabase stop -w packages/supabase",
    "supabase:status": "npx supabase status -w packages/supabase",
    "supabase:reset": "npx supabase db reset -w packages/supabase",
    "dev:local": "npm run supabase:start && npm run dev:web"
  }
}
