# ============================================================
# NotiFlow Web Dashboard — Environment Variables
# ============================================================
# Copy to .env.local and fill in values.
#
# LOCAL dev (supabase start):
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   Keys are printed by: cd packages/supabase && npx supabase status
#
# PRODUCTION (Supabase Cloud):
#   NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Edge Function proxy → Web API /api/parse
PARSE_API_SECRET=

# Cron job authentication secret (REQUIRED — set to a random secret string)
CRON_SECRET=

# AI API keys (optional — also configurable in DB settings table)
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# Vector Embedding
GOOGLE_GENERATIVE_AI_API_KEY=    # Gemini API key (optional, Ollama fallback)

# Firebase Cloud Messaging (Web Push)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Supabase Realtime (WebSocket subscriptions)
# Set to "true" in environments where Supabase Realtime WebSocket is unavailable
# (e.g. local Cloudflare Tunnel docker-compose). Leave unset for Vercel/production.
NEXT_PUBLIC_REALTIME_DISABLED=

# Admin notification email (sent when a new org signs up)
# Requires RESEND_API_KEY — get free key at resend.com (3000 emails/month free)
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=jinzhangxun@gmail.com
